{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "EDPrintTool",
  "identifier": "com.edprinttool.app",
  "version": "1.0.0",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:8189"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EDPrintTool",
        "width": 1000,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "closable": true,
        "resizable": true
      }
    ],
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "tooltip": "EDPrintTool — ZPL Label Printer"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "autostart": {
      "macosExtraArgs": [],
      "args": []
    }
  }
}
