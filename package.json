{
  "name": "edprinttool",
  "version": "1.0.0",
  "description": "Free QZ Tray alternative — send raw ZPL to Zebra thermal printers from any web app",
  "main": "src/electron.js",
  "scripts": {
    "start": "electron .",
    "server": "node src/server.js",
    "dev": "node --watch src/server.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64",
    "build:all": "electron-builder --win nsis portable --x64",
    "pack": "electron-builder --dir --x64",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "keywords": [
    "zebra",
    "zpl",
    "thermal",
    "printer",
    "label",
    "raw-print"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.edprinttool.app",
    "productName": "EDPrintTool",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ]
  }
}
